# FailureAtlas Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env or .env.local to git

# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://username:password@localhost:5432/failureatlas_dev"

# ─── AI / LLM (Groq — free tier available) ───────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY="gsk_your_groq_api_key_here"
RESEND_API_KEY="re_your_resend_api_key_here"

# ─── Authentication ───────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_at_least_32_chars"
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
JWT_SECRET="your_jwt_signing_secret_at_least_32_chars"

# ─── Development ─────────────────────────────────────────────
DEBUG="true"
LOG_LEVEL="debug"
NODE_ENV="development"
# Set to true to skip real embedding API calls during development
USE_MOCK_EMBEDDINGS="true"
