# FailureAtlas Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env or .env.local to git

# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://username:password@localhost:5432/failureatlas_dev"

# ─── AI / LLM (Groq — free tier available) ───────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY="gsk_your_groq_api_key_here"
# ─── Email / Gmail SMTP (Nodemailer) ─────────────────────────
GMAIL_USER="praxis.notifications@gmail.com"
GMAIL_APP_PASSWORD="xxxxxxxxxxxxxxxx"
EMAIL_FROM="Praxis <praxis.notifications@gmail.com>"

DEFAULT_DAILY_MISSION_TIME="07:30"
DEFAULT_PRACTICE_REMINDER_TIME="08:00"
DEFAULT_FAILURE_SUMMARY_TIME="22:30"
DEFAULT_WEEKLY_DIGEST_TIME="20:00"

# ─── AI / Gemini (Learning Sheets) ───────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash"


# ─── Authentication ───────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_at_least_32_chars"
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
JWT_SECRET="your_jwt_signing_secret_at_least_32_chars"

# ─── Development ─────────────────────────────────────────────
DEBUG="true"
LOG_LEVEL="debug"
NODE_ENV="development"
# Set to true to skip real embedding API calls during development
USE_MOCK_EMBEDDINGS="true"
CRON_SECRET="your_cron_secret_here"
