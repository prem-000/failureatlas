{
  "manifest_version": 3,
  "name": "FailureAtlas",
  "version": "1.0.0",
  "description": "FailureAtlas Chrome Extension — LeetCode submission capture",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webNavigation",
    "webRequest",
    "alarms"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.failureatlas.dev/*",
    "http://localhost:3000/*",
    "http://localhost:3000/api/*",
    "http://127.0.0.1:3000/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FailureAtlas"
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
