generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  password      String?
  name          String?
  image         String?
  provider      String?
  providerId    String?
  apiKey        String?           @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  diagnoses     DiagnosisResult[]
  learningPlans LearningPlan[]
  submissions   SubmissionEvent[]
  roadmapStates RoadmapState[]
  preferences   UserPreferences?
  dailyMissions DailyMission[]
  learningSheets   LearningSheet[]
  practiceReviews  PracticeReviewState[]
  practiceSessions PracticeSession[]
  practiceExports  PracticeExport[]
  notifications          Notification[]
  emailLogs              EmailLog[]
  notificationPreference NotificationPreference?

  @@map("users")
}

model Problem {
  id               String                @id @default(cuid())
  slug             String                @unique
  title            String
  difficulty       String
  topics           String[]
  url              String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  rootCauseHistory RootCauseOccurrence[]
  submissions      SubmissionEvent[]

  @@map("problems")
}

model SubmissionEvent {
  id                String            @id @default(cuid())
  userId            String
  problemId         String
  eventId           String            @unique
  submissionTraceId String?
  submissionHash    String?           @unique
  sessionId         String
  timestamp         DateTime
  status            String
  language          String
  code              String
  runtime           Int?
  memory            Int?
  testCasesPassed   Int?
  totalTestCases    Int?
  failedTestCase    String?
  timeSpent         Int
  attemptNumber     Int
  rapidSubmission   Boolean           @default(false)
  source            String            @default("extension") // 'extension' | 'interceptor' | 'merged'
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  diagnosis         DiagnosisResult?
  evidence          Evidence[]
  behaviorEvidence  BehaviorEvidence?
  networkEvidence   NetworkEvidence?
  codeEvidence      CodeEvidence?
  failureExplanation FailureExplanation?
  problem           Problem           @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([problemId])
  @@index([timestamp])
  @@index([submissionHash])
  @@map("submission_events")
}

model Evidence {
  id                  String                @id @default(cuid())
  submissionId        String
  type                String
  description         String
  confidence          Float
  source              String
  rawData             Json                  @default("{}")
  extractedAt         DateTime              @default(now())
  createdAt           DateTime              @default(now())
  submission          SubmissionEvent       @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  rootCauseHypotheses RootCauseHypothesis[]

  @@index([submissionId])
  @@map("evidence")
}

model RootCauseHypothesis {
  id            String    @id @default(cuid())
  evidenceId    String?
  rootCauseType String
  name          String
  confidence    Float
  createdAt     DateTime  @default(now())
  evidence      Evidence? @relation(fields: [evidenceId], references: [id])

  @@index([evidenceId])
  @@map("root_cause_hypotheses")
}

model RootCauseOccurrence {
  id                String   @id @default(cuid())
  rootCauseType     String
  problemId         String
  occurrenceCount   Int      @default(1)
  firstOccurrence   DateTime @default(now())
  lastOccurrence    DateTime @updatedAt
  averageConfidence Float    @default(0)
  problem           Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([rootCauseType, problemId])
  @@index([problemId])
  @@map("root_cause_occurrences")
}

model SystemicWeakness {
  id                  String              @id @default(cuid())
  name                String              @unique
  type                String
  severity            String
  confidence          Float
  frequency           Int                 @default(0)
  lastOccurrence      DateTime            @default(now())
  riskIndex           Float               @default(0)
  pageRankScore       Float               @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  diagnoses           DiagnosisResult[]   @relation("PrimaryWeakness")
  diagnosisWeaknesses DiagnosisWeakness[]
  strategies          LearningStrategy[]

  @@map("systemic_weaknesses")
}

model DiagnosisResult {
  id                String                   @id @default(cuid())
  userId            String
  submissionId      String                   @unique
  primaryWeaknessId String
  generatedAt       DateTime                 @default(now())
  progressMetrics   Json                     @default("{}")
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  
  // Cache Fields
  fingerprint       String?                  @unique
  codeHash          String?
  modelVersion      String?
  diagnosisJson     Json?

  primaryWeakness   SystemicWeakness         @relation("PrimaryWeakness", fields: [primaryWeaknessId], references: [id])
  submission        SubmissionEvent          @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations   LearningRecommendation[]

  @@index([userId])
  @@index([submissionId])
  @@index([codeHash])
  @@map("diagnosis_results")
}

model DiagnosisWeakness {
  id          String           @id @default(cuid())
  diagnosisId String
  weaknessId  String
  isSecondary Boolean          @default(true)
  createdAt   DateTime         @default(now())
  weakness    SystemicWeakness @relation(fields: [weaknessId], references: [id], onDelete: Cascade)

  @@unique([diagnosisId, weaknessId, isSecondary])
  @@index([weaknessId])
  @@map("diagnosis_weaknesses")
}

model LearningStrategy {
  id               String                   @id @default(cuid())
  weaknessId       String
  name             String
  description      String
  estimatedTime    Int
  priority         String
  practiceProblems String[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  recommendations  LearningRecommendation[]
  weakness         SystemicWeakness         @relation(fields: [weaknessId], references: [id], onDelete: Cascade)

  @@index([weaknessId])
  @@map("learning_strategies")
}

model LearningRecommendation {
  id          String           @id @default(cuid())
  diagnosisId String
  strategyId  String
  completed   Boolean          @default(false)
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  diagnosis   DiagnosisResult  @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)
  strategy    LearningStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([diagnosisId])
  @@index([strategyId])
  @@map("learning_recommendations")
}

model LearningPlan {
  id        String   @id @default(cuid())
  userId    String
  title     String
  progress  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("learning_plans")
}

model TextEmbedding {
  id             String   @id @default(cuid())
  content        String
  embedding      Json?
  embeddingModel String   @default("text-embedding-3-large")
  sourceType     String
  sourceId       String
  createdAt      DateTime @default(now())

  @@index([sourceType, sourceId])
  @@map("text_embeddings")
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("api_keys")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  details   Json?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
  @@map("audit_logs")
}

model LeetcodeProblem {
  id            String   @id @default(cuid())
  leetcodeId    Int      @unique
  slug          String   @unique
  title         String
  difficulty    String
  topics        String[]
  patterns      String[]
  prerequisites String[]
  createdAt     DateTime @default(now())

  @@map("leetcode_problems")
}

model RoadmapState {
  id           String   @id @default(cuid())
  userId       String
  topic        String
  currentLevel Int      @default(1)
  levels       Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topic])
  @@index([userId])
  @@map("roadmap_states")
}

model UserPreferences {
  id                 String   @id @default(cuid())
  userId             String   @unique
  dailyMissionEmail  Boolean  @default(true)
  preferredTime      String   @default("08:00")
  leetcodeUsername   String?
  codeforcesUsername String?
  codechefUsername   String?
  atcoderUsername    String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model DailyMission {
  id                    String   @id @default(cuid())
  userId                String
  primaryProblemSlug    String
  secondaryProblemSlug  String?
  failureRisk           Float
  successProbability    Float
  aiHint                String
  learningGain          Json
  missionDate           DateTime
  completed             Boolean  @default(false)
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("daily_missions")
}

// ─── Typed evidence tables (Network Interceptor Pipeline) ─────────────────────

model BehaviorEvidence {
  id              String          @id @default(cuid())
  submissionId    String          @unique
  typingTime      Int?            // milliseconds spent typing
  editorEvents    Int?            // total editor interactions
  tabSwitches     Int?            // times user switched tabs
  focusLoss       Int?            // times editor lost focus
  sessionDuration Int?            // total session duration in seconds
  rawData         Json            @default("{}")
  createdAt       DateTime        @default(now())
  submission      SubmissionEvent @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("behavior_evidence")
}

model NetworkEvidence {
  id                  String          @id @default(cuid())
  submissionId        String          @unique
  requestMethod       String?
  requestUrl          String?
  requestHeaders      Json            @default("{}")
  requestBody         Json            @default("{}")
  requestSize         Int?
  requestTimestamp    DateTime?
  responseStatusCode  Int?
  responseHeaders     Json            @default("{}")
  responseBody        Json            @default("{}")
  responseSize        Int?
  responseTimestamp   DateTime?
  verdict             String?         // WA, TLE, MLE, AC, RE, CE
  runtime             Int?            // ms from response body
  memory              Float?          // MB from response body
  totalTestcases      Int?
  passedTestcases     Int?
  failedTestcase      String?
  serverProcessingMs  Int?            // server-side processing time
  latencyMs           Int?            // total round-trip ms
  retryCount          Int             @default(0)
  pollingFrequency    Float?          // polls per second
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  submission          SubmissionEvent @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("network_evidence")
}

model CodeEvidence {
  id            String          @id @default(cuid())
  submissionId  String          @unique
  previousCode  String?
  currentCode   String?
  diff          String?
  changedLines  Int?
  confidence    Float?
  createdAt     DateTime        @default(now())
  submission    SubmissionEvent @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("code_evidence")
}

model FailureExplanation {
  id                           String          @id @default(cuid())
  submissionId                 String          @unique
  rootCause                    String
  rootCauseCategory            String
  confidence                   Float
  reason                       String
  logicBreakdown               String
  learningConcept              String
  recommendation               String
  estimatedLearningTimeMinutes Int
  evidenceItems                Json            @default("[]")
  representativeTestCase       Json?
  recurringPatterns            Json            @default("[]")
  generatedAt                  DateTime        @default(now())
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt
  submission                   SubmissionEvent @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("failure_explanations")
}

// ─── Learning Sheets (Gemini-powered structured content) ──────────────────────

model LearningSheet {
  id          String   @id @default(cuid())
  userId      String?                  // Nullable: global sheets are null, user bookmarked sheets have their userId
  topic       String
  slug        String   @unique
  category    String
  difficulty  String
  language    String   @default("English")
  version     Int      @default(1)
  json        Json
  hash        String
  generatedBy String   // e.g. "gemini-2.5-flash"
  bookmarked  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topic, difficulty, language, version])
  @@index([category])
  @@index([slug])
  @@map("learning_sheets")
}

model PracticeReviewState {
  id            String                  @id @default(cuid())
  userId        String
  problemId     String                  // Unique problem ID/slug per platform (e.g. '704', 'two-sum')
  title         String
  difficulty    String                  // 'Easy' | 'Medium' | 'Hard'
  platform      String                  // 'LeetCode' | 'Codeforces' | 'CodeChef' | 'AtCoder'
  solveDate     DateTime                @default(now())
  lastReview    DateTime?
  nextReview    DateTime                @default(now())
  repetitions   Int                     @default(0)
  easeFactor    Float                   @default(2.5)
  interval      Int                     @default(1) // In days
  reviewAgain   Boolean                 @default(false)
  personalNotes String                  @default("")
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  history       PracticeReviewHistory[]
  sessionItems  PracticeSessionItem[]
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, problemId])
  @@index([userId])
  @@index([nextReview])
  @@map("practice_review_states")
}

model PracticeReviewHistory {
  id               String              @id @default(cuid())
  reviewStateId    String
  sessionId        String?
  reviewedAt       DateTime            @default(now())
  quality          Int                 // 1-5 quality score
  easeFactorBefore Float
  easeFactorAfter  Float
  intervalBefore   Int
  intervalAfter    Int
  repetitions      Int
  reviewState      PracticeReviewState @relation(fields: [reviewStateId], references: [id], onDelete: Cascade)
  session          PracticeSession?    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([reviewStateId])
  @@index([sessionId])
  @@map("practice_review_histories")
}

enum PracticeStrategy {
  PRIORITY
  WEAKEST_TOPIC
  MIXED
}

model PracticeSession {
  id             String                @id @default(cuid())
  userId         String
  startedAt      DateTime              @default(now())
  completedAt    DateTime?
  strategy       PracticeStrategy
  filterTopic    String?
  averageRecall  Float?
  retentionRate  Float?
  currentIndex   Int                   @default(0)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          PracticeSessionItem[]
  history        PracticeReviewHistory[]

  @@index([userId])
  @@map("practice_sessions")
}

model PracticeSessionItem {
  id                    String              @id @default(cuid())
  sessionId             String
  practiceReviewStateId String
  order                 Int
  completed             Boolean             @default(false)
  session               PracticeSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  review                PracticeReviewState @relation(fields: [practiceReviewStateId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([practiceReviewStateId])
  @@map("practice_session_items")
}

model PracticeExport {
  id        String   @id @default(cuid())
  userId    String
  payload   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("practice_exports")
}

// ─── Notification & Email Dispatch System ────────────────────────────────────

enum NotificationType {
  WELCOME
  FAILURE_SUMMARY
  DAILY_MISSION
  PRACTICE_REMINDER
  WEEKLY_DIGEST
  ENGAGEMENT_REMINDER
}

enum NotificationCategory {
  SYSTEM
  LEARNING
  REMINDER
  REPORT
  WELCOME
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  RETRYING
  SKIPPED
}

model Notification {
  id                   String             @id @default(cuid())
  userId               String
  type                 NotificationType
  category             NotificationCategory
  title                String
  payload              Json               @default("{}")
  version              Int                @default(1)
  scheduledAt          DateTime
  processingStartedAt  DateTime?
  processingFinishedAt DateTime?
  sentAt               DateTime?
  status               NotificationStatus @default(PENDING)
  error                String?
  retryCount           Int                @default(0)
  dedupeKey            String?            @unique
  createdAt            DateTime           @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs EmailLog[]

  @@unique([userId, type, scheduledAt])
  @@index([userId])
  @@index([scheduledAt])
  @@index([status])
  @@map("notifications")
}

model EmailLog {
  id                String               @id @default(cuid())
  userId            String?
  notificationId    String?
  recipient         String
  emailType         NotificationType
  category          NotificationCategory
  subject           String
  status            NotificationStatus
  providerMessageId String?
  failedReason      String?
  providerLatency   Int?
  retryCount        Int                  @default(0)
  templateVersion   Int
  createdAt         DateTime             @default(now())

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([notificationId])
  @@index([recipient])
  @@index([createdAt])
  @@map("email_logs")
}

model NotificationPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique
  dailyMission       Boolean  @default(true)
  practiceReminder   Boolean  @default(true)
  failureSummary     Boolean  @default(true)
  weeklyDigest       Boolean  @default(true)
  engagementReminder Boolean  @default(true)
  marketing          Boolean  @default(false)
  timezone           String   @default("UTC")
  quietHoursStart    String   @default("22:00") // Local-time HH:mm
  quietHoursEnd      String   @default("07:00") // Local-time HH:mm
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}
